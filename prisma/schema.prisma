generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(uuid())
  username  String    @unique
  avatar    String    @default("")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  firstname String
  lastname  String
  articles  Article[]

  @@map("users")
}

model Category {
  id           String    @id @default(uuid())
  name         String    @unique
  emoji        String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  colors       Json
  mainArticles Article[] @relation("MainCategory")
  articles     Article[] @relation("ArticleCategories")

  @@map("categories")
}

model Article {
  id             String        @id @default(uuid())
  content        Json
  title          String
  description    String?
  status         ArticleStatus @default(draft)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  authorId       String
  mainCategoryId String
  publishedAt    DateTime?
  author         User          @relation(fields: [authorId], references: [id])
  mainCategory   Category      @relation("MainCategory", fields: [mainCategoryId], references: [id])
  categories     Category[]    @relation("ArticleCategories")

  @@map("articles")
}

enum ArticleStatus {
  published
  draft
  archived
  review
}
