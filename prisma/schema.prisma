generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  firstname String
  lastname  String
  avatar    String   @default("")
  
  articles  Article[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@map("users")
}

model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  emoji       String
  
  colors      Json
  
  articles    Article[] @relation("ArticleCategories")
  mainArticles Article[] @relation("MainCategory")
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("categories")
}

model Article {
  id            String   @id @default(uuid())
  title         String
  description   String?
  content       Json     // Храним Content как JSON
  
  authorId      String
  author        User     @relation(fields: [authorId], references: [id])
  
  mainCategoryId String
  mainCategory  Category @relation("MainCategory", fields: [mainCategoryId], references: [id])
  
  categories    Category[] @relation("ArticleCategories")
  
  status        ArticleStatus @default(draft)
  
  publishedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@map("articles")
}

enum ArticleStatus {
  published
  draft
  archived
  review
}
